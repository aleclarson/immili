{
  "name": "immili",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/immili.git"
  },
  "files": [
    "dist",
    "docs",
    "examples"
  ],
  "type": "module",
  "peerDependencies": {
    "immer": ">=8",
    "react": ">=18"
  },
  "exports": {
    "types": "./dist/index.d.mts",
    "default": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit && tsc -p examples --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "immer": "*",
    "oxfmt": "*",
    "oxlint": "*",
    "radashi": "*",
    "react": "*",
    "tsdown": "*",
    "tsnapi": "^0.1.1",
    "typescript": "*",
    "vitest": "*"
  }
}
